# Vercel Postgres (any of POSTGRES_URL or DATABASE_URL works)
POSTGRES_URL="postgresql://user:pass@host:5432/db"

# Vercel Blob (set automatically when you add the Blob store in Vercel)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Auth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me"

# Optional: set to allow seeding the first admin user on first run
# If unset, no seed runs. Set both to bootstrap.
SEED_ADMIN_EMAIL="brett@thebault.co.uk"
SEED_ADMIN_PASSWORD="change-me"

# Public site URL (used for absolute links in emails, etc.)
NEXT_PUBLIC_SITE_URL="https://dump.thebnut.com"
